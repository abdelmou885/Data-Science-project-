# 4. TARGET CLEANING
# =========================

# Keep only rows where error_type exists
df = merged.dropna(subset=["error_type"]).copy()

# Remove impossible/dirty values if needed
# Example: some rows seem to contain strange values in quality-related columns in the data file
numeric_cols_all = df.select_dtypes(include=[np.number]).columns.tolist()

for col in numeric_cols_all:
    df[col] = pd.to_numeric(df[col], errors="coerce")

print("\nFinal modeling shape:", df.shape)
print("\nError type distribution:")
print(df["error_type"].value_counts())


# 5. BASIC DESCRIPTION
# =========================

